# PeerSphere Environment Configuration
# Copy this file to .env and edit the values

# REQUIRED: Change this to a long random string in production!
SECRET_KEY=peersphere-super-secret-key-change-me-in-production

# Database (default: SQLite inside the container volume)
DATABASE_URL=sqlite:////app/backend/instance/peersphere.db

# Set to 'development' and '1' to enable hot-reload (dev only)
FLASK_ENV=production
FLASK_DEBUG=0
